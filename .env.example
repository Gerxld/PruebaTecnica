# ── Gemini LLM (requerido para el chat assistant) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Neo4j Desktop (opcional — el sistema usa NetworkX si no está disponible) ──
# Crea una base de datos en Neo4j Desktop y copia los datos de conexión aquí.
# Por defecto Neo4j Desktop usa bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
